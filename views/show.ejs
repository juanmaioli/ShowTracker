<% 
  const allImages = [];
  const backgrounds = artworks.backgrounds || [];
  const posters = artworks.posters || [];
  const maxLength = Math.max(backgrounds.length, posters.length);
  for (let i = 0; i < maxLength; i++) {
    if (i < backgrounds.length) {
      allImages.push({ url: backgrounds[i], type: 'Fondo' });
    }
    if (i < posters.length) {
      allImages.push({ url: posters[i], type: 'Póster' });
    }
  }

  // Generador pseudo-aleatorio determinista para el diseño de la galería
  function getHashCode(str) {
    let hash = 0;
    for (let i = 0; i < str.length; i++) {
      hash = str.charCodeAt(i) + ((hash << 5) - hash);
    }
    return Math.abs(hash);
  }
%>

<% if (allImages.length > 0) { %>
<!-- Cargar scripts de Packery e imagesLoaded -->
<script src="https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js"></script>
<script src="https://unpkg.com/packery@2/dist/packery.pkgd.min.js"></script>

<!-- Galería de la Serie (Masonry) -->
<div class="card glass-card p-4 rounded-4 shadow border-0 mb-5">
  <h2 class="fs-4 fw-bold mb-4 d-flex align-items-center gap-2">
    <span>🖼️</span> Galería de Artworks locales
  </h2>

  <div class="masonry-grid" id="masonryGrid">
    <div class="masonry-grid-sizer"></div>
    
    <% allImages.forEach((img, idx) => { %>
      <% 
        const hash = getHashCode(img.url);
        let widthClass = '';
        if (img.type === 'Póster') {
          // Un 15% de los pósteres serán de doble ancho (destacados)
          widthClass = (hash % 7 === 0) ? 'grid-item-double' : '';
        } else if (img.type === 'Fondo') {
          // Los fondos se distribuyen en un 20% triple, 50% doble y 30% simple
          const mod = hash % 10;
          if (mod < 2) {
            widthClass = 'grid-item-triple';
          } else if (mod < 7) {
            widthClass = 'grid-item-double';
          } else {
            widthClass = '';
          }
        }
      %>
      <div class="masonry-grid-item <%= widthClass %>" onclick="openPhotoLightbox(<%= idx %>)">
        <div class="masonry-card rounded-4 overflow-hidden position-relative shadow-sm">
          <img src="<%= img.url %>" alt="<%= img.type %> de <%= show.name %>" class="w-100 h-auto d-block">
          
          <div class="masonry-overlay d-flex flex-column justify-content-between p-3 position-absolute top-0 start-0 w-100 h-100">
            <div class="text-end">
              <a href="<%= img.url %>" target="_blank" onclick="event.stopPropagation();" class="btn btn-sm btn-dark bg-opacity-75 border-0 rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px;" title="Abrir en pestaña nueva">
                <span>↗</span>
              </a>
            </div>
            <div class="text-start">
              <span class="badge bg-dark bg-opacity-75 border border-secondary border-opacity-25 py-1 px-2 small">
                <%= img.type %> <%= idx + 1 %>
              </span>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Lightbox Modal para Galería Masonry -->
<div class="modal fade" id="photoLightboxModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content bg-transparent border-0 shadow-none text-white">
      <div class="modal-body p-0 position-relative text-center d-flex flex-column align-items-center justify-content-center">
        <!-- Botón para cerrar -->
        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Cerrar" style="z-index: 1050; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8));"></button>
        
        <!-- Contenedor principal con navegación -->
        <div class="d-flex align-items-center justify-content-between w-100" style="max-height: 85vh;">
          <!-- Flecha izquierda -->
          <button class="btn btn-link text-white p-2 border-0" id="lightboxPrevBtn" onclick="navigateLightbox(-1)" style="font-size: 2.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.8); z-index: 1040; text-decoration: none;">
            ◀
          </button>
          
          <!-- Imagen ampliada -->
          <div class="mx-auto overflow-hidden rounded-4 shadow-lg border border-secondary border-opacity-10 bg-black bg-opacity-75" style="max-width: 80%; max-height: 80vh;">
            <img id="lightboxImg" src="" alt="Foto ampliada" class="img-fluid object-fit-contain" style="max-height: 80vh; transition: opacity 0.2s ease;">
          </div>
          
          <!-- Flecha derecha -->
          <button class="btn btn-link text-white p-2 border-0" id="lightboxNextBtn" onclick="navigateLightbox(1)" style="font-size: 2.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.8); z-index: 1040; text-decoration: none;">
            ▶
          </button>
        </div>
        
        <!-- Barra de herramientas inferior -->
        <div class="mt-3 bg-dark bg-opacity-75 py-2 px-4 rounded-pill border border-secondary border-opacity-25 d-flex align-items-center gap-3" style="backdrop-filter: blur(10px);">
          <span id="lightboxIndexLabel" class="text-white fw-medium fs-6">Foto X de Y</span>
          <span class="text-white-50">|</span>
          <a href="" id="lightboxExternalLink" target="_blank" class="lightbox-external-link text-decoration-none d-inline-flex align-items-center gap-1 small text-white" title="Abrir en pestaña nueva">
            <span>↗</span>
            <span>Abrir en pestaña nueva</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Acordeón de Temporadas -->
<h2 class="fs-4 fw-bold mb-4 d-flex align-items-center gap-2">
  <span>📅</span> Temporadas y Episodios
</h2>

<div class="accordion accordion-flush rounded-4 overflow-hidden border border-secondary border-opacity-25" id="seasonsAccordion">
  <% seasons.forEach((season, index) => { 
     const seasonTotal = season.episodes.length;
     const seasonWatched = season.episodes.filter(e => e.watched === 1).length;
     const allWatched = seasonTotal === seasonWatched;
  %>
    <div class="accordion-item bg-dark bg-opacity-50">
      <h2 class="accordion-header m-0">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 p-3 bg-dark bg-opacity-25 text-light border-bottom border-secondary border-opacity-10">
          <div class="d-flex align-items-center gap-2">
            <span class="fs-5">📁</span>
            <span class="fw-bold">
              <%= season.name %>
              <% 
                const firstEpWithDate = season.episodes.find(e => e.air_date && e.air_date.trim() !== '');
                if (firstEpWithDate) {
                  const year = firstEpWithDate.air_date.split('-')[0];
                  if (year) {
              %>
                (<%= year %>)
              <% 
                  }
                } 
              %>
            </span>
          </div>
          
          <div class="d-flex align-items-center gap-3 ms-auto py-1">
            <!-- Calificación por estrellas -->
            <div class="star-rating d-flex align-items-center gap-1 me-2" data-series-id="<%= show.id %>" data-season-number="<%= season.number %>" data-rating="<%= season.rating || 0 %>">
              <% for (let i = 1; i <= 5; i++) { %>
                <span class="star cursor-pointer fs-5" data-value="<%= i %>" style="color: <%= i <= (season.rating || 0) ? '#ffc107' : '#6c757d' %>; transition: color 0.2s ease;" title="Calificar con <%= i %> estrellas">
                  <%= i <= (season.rating || 0) ? '★' : '☆' %>
                </span>
              <% } %>
            </div>

            <!-- Contador de la temporada -->
            <span id="season-count-<%= season.number %>" class="badge bg-secondary bg-opacity-50 text-secondary-emphasis rounded-pill small">
              <%= seasonWatched %> / <%= seasonTotal %> vistos
            </span>
            <!-- Botón para marcar temporada completa -->
            <button class="btn btn-sm <%= allWatched ? 'btn-outline-warning' : 'btn-outline-success' %> rounded-pill py-0 px-2 btn-season-toggle" 
                    data-series-id="<%= show.id %>" 
                    data-season-number="<%= season.number %>" 
                    data-watched="<%= allWatched ? 'true' : 'false' %>">
              <%= allWatched ? 'Desmarcar temporada' : 'Completar temporada' %>
            </button>

            <!-- Flecha para contraer/expandir -->
            <button class="btn btn-link text-light p-1 ms-2 accordion-toggle-arrow" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSeason-<%= season.number %>" aria-expanded="false" style="text-decoration: none;" title="Mostrar/Ocultar episodios">
              <span class="collapse-icon">▼</span>
            </button>
          </div>
        </div>
      </h2>
      
      <div id="collapseSeason-<%= season.number %>" class="accordion-collapse collapse" data-bs-parent="#seasonsAccordion">
        <div class="accordion-body p-0">
          <div class="list-group list-group-flush">
            <% season.episodes.forEach(ep => { %>
              <div class="list-group-item bg-dark bg-opacity-10 text-light border-bottom border-secondary border-opacity-10 d-flex align-items-center gap-3 p-3">
                <!-- Checkbox -->
                <div class="form-check fs-5 mb-0">
                  <input class="form-check-input episode-checkbox cursor-pointer" type="checkbox" 
                         value="<%= ep.id %>" 
                         id="ep-<%= ep.id %>" 
                         data-season-number="<%= ep.season_number %>"
                         <%= ep.watched === 1 ? 'checked' : '' %>>
                </div>
                
                <!-- Info Episodio -->
                <div class="flex-grow-1">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <label class="form-check-label fw-semibold cursor-pointer" for="ep-<%= ep.id %>">
                      Episodio <%= ep.episode_number %>: <%= ep.name %>
                    </label>
                    <% if (ep.air_date) { %>
                      <span class="small"><%= ep.air_date %></span>
                    <% } %>
                  </div>
                  <% if (ep.overview) { %>
                    <p class="small mb-0 mt-1"><%= ep.overview %></p>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<script>
  // Lógica de Galería Masonry y Lightbox
  const artistImages = <%- (typeof allImages !== 'undefined' && allImages && allImages.length > 0) ? JSON.stringify(allImages.map(img => img.url)) : '[]' %>;
  let currentPhotoIndex = 0;
  let photoLightboxModalInstance = null;

  function openPhotoLightbox(index) {
    currentPhotoIndex = index;
    const imgUrl = artistImages[currentPhotoIndex];
    
    const lightboxImg = document.getElementById('lightboxImg');
    const indexLabel = document.getElementById('lightboxIndexLabel');
    const externalLink = document.getElementById('lightboxExternalLink');
    if (!lightboxImg || !indexLabel) return;
    
    lightboxImg.src = imgUrl;
    indexLabel.textContent = `Imagen ${currentPhotoIndex + 1} de ${artistImages.length}`;
    if (externalLink) externalLink.href = imgUrl;
    
    if (!photoLightboxModalInstance) {
      const modalEl = document.getElementById('photoLightboxModal');
      photoLightboxModalInstance = new bootstrap.Modal(modalEl);
      
      modalEl.addEventListener('click', (e) => {
        const isClickOnInteractive = e.target.closest('#lightboxImg') || 
                                     e.target.closest('#lightboxPrevBtn') || 
                                     e.target.closest('#lightboxNextBtn') ||
                                     e.target.closest('#lightboxIndexLabel') ||
                                     e.target.closest('#lightboxExternalLink') ||
                                     e.target.closest('.rounded-pill');
        if (!isClickOnInteractive) {
          photoLightboxModalInstance.hide();
        }
      });
    }
    
    photoLightboxModalInstance.show();
  }

  function navigateLightbox(direction) {
    if (artistImages.length <= 1) return;
    
    const lightboxImg = document.getElementById('lightboxImg');
    const indexLabel = document.getElementById('lightboxIndexLabel');
    const externalLink = document.getElementById('lightboxExternalLink');
    if (!lightboxImg || !indexLabel) return;
    
    currentPhotoIndex = (currentPhotoIndex + direction + artistImages.length) % artistImages.length;
    const nextImgUrl = artistImages[currentPhotoIndex];
    
    lightboxImg.style.opacity = '0';
    setTimeout(() => {
      lightboxImg.src = nextImgUrl;
      indexLabel.textContent = `Imagen ${currentPhotoIndex + 1} de ${artistImages.length}`;
      if (externalLink) externalLink.href = nextImgUrl;
      lightboxImg.style.opacity = '1';
    }, 150);
  }

  // Teclado para modal
  document.addEventListener('keydown', (e) => {
    const photoModalEl = document.getElementById('photoLightboxModal');
    const isPhotoModalOpen = photoModalEl && photoModalEl.classList.contains('show');
    
    if (isPhotoModalOpen) {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        navigateLightbox(1);
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        navigateLightbox(-1);
      }
    }
  });

  // Inicializar Packery (llena los espacios vacíos / bin-packing)
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.querySelector('#masonryGrid');
    if (grid) {
      imagesLoaded(grid, () => {
        new Packery(grid, {
          itemSelector: '.masonry-grid-item',
          columnWidth: '.masonry-grid-sizer',
          percentPosition: true,
          gutter: 15
        });
      });
    }
  });

  // Manejar toggle de episodios individuales
  document.querySelectorAll('.episode-checkbox').forEach(chk => {
    chk.addEventListener('change', async (e) => {
      const checkbox = e.currentTarget;
      const episodeId = checkbox.value;
      const isChecked = checkbox.checked;
      const seasonNum = checkbox.dataset.seasonNumber;

      try {
        const response = await fetch('/episodes/toggle-watched', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ episodeId })
        });
        
        const data = await response.json();
        if (data.success) {
          // Actualizar barra de progreso de la serie
          updateSeriesProgress(data.seriesProgress);
          
          // Actualizar contador de la temporada
          updateSeasonCounter(seasonNum);
        } else {
          checkbox.checked = !isChecked; // Deshacer cambio si falló
        }
      } catch (err) {
        console.error(err);
        checkbox.checked = !isChecked;
      }
    });
  });

  // Manejar toggle de temporadas completas
  document.querySelectorAll('.btn-season-toggle').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const button = e.currentTarget;
      const seriesId = button.dataset.seriesId;
      const seasonNumber = button.dataset.seasonNumber;
      const currentWatched = button.dataset.watched === 'true';
      const targetWatched = !currentWatched;

      try {
        const response = await fetch('/episodes/toggle-season', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ seriesId, seasonNumber, watched: targetWatched })
        });

        const data = await response.json();
        if (data.success) {
          // Actualizar los checkboxes visualmente
          const checkboxes = document.querySelectorAll(`.episode-checkbox[data-season-number="${seasonNumber}"]`);
          checkboxes.forEach(chk => {
            if (chk.checked !== targetWatched) {
              chk.checked = targetWatched;
            }
          });

          // Actualizar el botón
          button.dataset.watched = targetWatched ? 'true' : 'false';
          button.innerHTML = targetWatched ? 'Desmarcar temporada' : 'Completar temporada';
          button.className = `btn btn-sm ${targetWatched ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill py-0 px-2 btn-season-toggle`;

          // Actualizar barra de progreso
          updateSeriesProgress(data.seriesProgress);

          // Actualizar contador
          const countBadge = document.getElementById(`season-count-${seasonNumber}`);
          const total = checkboxes.length;
          countBadge.innerText = `${targetWatched ? total : 0} / ${total} vistos`;
        }
      } catch (err) {
        console.error(err);
      }
    });
  });

  // Manejar toggle de serie completa
  document.querySelectorAll('.btn-series-toggle').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const seriesId = e.currentTarget.dataset.seriesId;
      const currentWatched = e.currentTarget.dataset.watched === 'true';
      const targetWatched = !currentWatched;

      try {
        const response = await fetch('/episodes/toggle-series', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ seriesId, watched: targetWatched })
        });

        const data = await response.json();
        if (data.success) {
          // 1. Actualizar todos los checkboxes de episodios en el DOM
          document.querySelectorAll('.episode-checkbox').forEach(chk => chk.checked = targetWatched);

          // 2. Actualizar todos los botones de temporada
          document.querySelectorAll('.btn-season-toggle').forEach(tBtn => {
            tBtn.dataset.watched = targetWatched ? 'true' : 'false';
            tBtn.innerHTML = targetWatched ? 'Desmarcar temporada' : 'Completar temporada';
            tBtn.className = `btn btn-sm ${targetWatched ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill py-0 px-2 btn-season-toggle`;
          });

          // 3. Actualizar todos los contadores de las temporadas
          document.querySelectorAll('[id^="season-count-"]').forEach(badge => {
            const seasonNum = badge.id.replace('season-count-', '');
            const total = document.querySelectorAll(`.episode-checkbox[data-season-number="${seasonNum}"]`).length;
            badge.innerText = `${targetWatched ? total : 0} / ${total} vistos`;
          });

          // 4. Actualizar barra de progreso de la serie
          updateSeriesProgress(data.seriesProgress);

          // 5. Actualizar el estado de todos los botones de toggle de la serie (tanto premium como estándar)
          document.querySelectorAll('.btn-series-toggle').forEach(sBtn => {
            sBtn.dataset.watched = targetWatched ? 'true' : 'false';
            sBtn.innerHTML = targetWatched ? 'Desmarcar toda la serie' : 'Completar toda la serie';
            sBtn.className = `btn btn-sm ${targetWatched ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill py-0 px-2 btn-series-toggle`;
          });
        }
      } catch (err) {
        console.error(err);
      }
    });
  });

  function updateSeriesProgress(progress) {
    // Buscar y actualizar todas las instancias de barras de progreso y textos en la página
    document.querySelectorAll('#series-progress-bar').forEach(bar => {
      bar.style.width = `${progress.percentage}%`;
      bar.setAttribute('aria-valuenow', progress.percentage);
    });
    
    document.querySelectorAll('#series-progress-text').forEach(txt => {
      txt.innerText = `${progress.watched} / ${progress.total} (${progress.percentage}%)`;
    });

    // Actualizar el estado del botón de marcar serie completa dinámicamente
    const allWatched = progress.total === progress.watched;
    document.querySelectorAll('.btn-series-toggle').forEach(sBtn => {
      sBtn.dataset.watched = allWatched ? 'true' : 'false';
      sBtn.innerHTML = allWatched ? 'Desmarcar toda la serie' : 'Completar toda la serie';
      sBtn.className = `btn btn-sm ${allWatched ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill py-0 px-2 btn-series-toggle`;
    });
  }

  function updateSeasonCounter(seasonNum) {
    const checkboxes = document.querySelectorAll(`.episode-checkbox[data-season-number="${seasonNum}"]`);
    const total = checkboxes.length;
    const watched = Array.from(checkboxes).filter(chk => chk.checked).length;
    
    const countBadge = document.getElementById(`season-count-${seasonNum}`);
    if (countBadge) {
      countBadge.innerText = `${watched} / ${total} vistos`;
    }

    // Actualizar también el estado del botón de temporada
    const btn = document.querySelector(`.btn-season-toggle[data-season-number="${seasonNum}"]`);
    if (btn) {
      const allWatched = total === watched;
      btn.dataset.watched = allWatched ? 'true' : 'false';
      btn.innerHTML = allWatched ? 'Desmarcar temporada' : 'Completar temporada';
      btn.className = `btn btn-sm ${allWatched ? 'btn-outline-warning' : 'btn-outline-success'} rounded-pill py-0 px-2 btn-season-toggle`;
    }
  }

  // Manejar calificación por estrellas de temporadas
  document.querySelectorAll('.star-rating').forEach(container => {
    const stars = container.querySelectorAll('.star');
    const seriesId = container.dataset.seriesId;
    const seasonNumber = container.dataset.seasonNumber;

    // Efecto hover al pasar el mouse
    stars.forEach(star => {
      star.addEventListener('mouseenter', () => {
        const val = parseInt(star.dataset.value);
        stars.forEach((s, idx) => {
          s.innerText = (idx < val) ? '★' : '☆';
          s.style.color = (idx < val) ? '#ffc107' : '#6c757d';
        });
      });
    });

    container.addEventListener('mouseleave', () => {
      const currentRating = parseFloat(container.dataset.rating) || 0;
      stars.forEach((s, idx) => {
        s.innerText = (idx < currentRating) ? '★' : '☆';
        s.style.color = (idx < currentRating) ? '#ffc107' : '#6c757d';
      });
    });

    // Evento de clic para calificar
    stars.forEach(star => {
      star.addEventListener('click', async () => {
        const val = parseInt(star.dataset.value);
        
        try {
          const response = await fetch('/series/rate-season', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ seriesId, seasonNumber, rating: val })
          });
          
          const data = await response.json();
          if (data.success) {
            container.dataset.rating = val;
            
            // Actualizar estrellas visualmente
            stars.forEach((s, idx) => {
              s.innerText = (idx < val) ? '★' : '☆';
              s.style.color = (idx < val) ? '#ffc107' : '#6c757d';
            });
            
            // Actualizar todas las instancias del promedio de la serie (score) en los badges
            document.querySelectorAll('.series-score-badge').forEach(badge => {
              badge.innerHTML = `⭐ ${data.averageRating}`;
            });
          }
        } catch (err) {
          console.error('Error al enviar la calificación:', err);
        }
      });
    });

    // Lógica para el botón de actualizar serie
    document.querySelectorAll('.btn-update-series-action').forEach(btn => {
      btn.addEventListener('click', async () => {
        const seriesId = btn.dataset.seriesId;
        const icon = btn.querySelector('.update-icon');
        const text = btn.querySelector('.update-text');
        
        btn.disabled = true;
        if (text) text.innerText = 'Actualizando...';
        if (icon) {
          icon.style.display = 'inline-block';
          icon.style.animation = 'spin 1.2s linear infinite';
        }
        
        try {
          const response = await fetch(`/series/${seriesId}/actualizar`, {
            method: 'POST'
          });
          
          if (!response.ok) {
            throw new Error(`HTTP error ${response.status}`);
          }
          
          const data = await response.json();
          if (data.success) {
            window.location.reload();
          } else {
            throw new Error(data.error || 'Error desconocido');
          }
        } catch (err) {
          console.error('Error al actualizar la serie:', err);
          alert(`Error al actualizar la serie: ${err.message}`);
          
          btn.disabled = false;
          if (text) text.innerText = 'Actualizar';
          if (icon) {
            icon.style.animation = 'none';
          }
        }
      });
    });
  });
</script>

