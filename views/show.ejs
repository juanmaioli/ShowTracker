      width: calc(((100% - 30px) / 3) * 2 + 15px) !important;
    }
  }
  @media (min-width: 992px) {
    .grid-item-double {
      width: calc(((100% - 60px) / 5) * 2 + 15px) !important;
    }
  }
  @media (min-width: 1200px) {
    .grid-item-double {
      width: calc(((100% - 90px) / 7) * 2 + 15px) !important;
    }
  }

  /* Elementos de triple ancho */
  .grid-item-triple {
    width: 100% !important;
  }
  @media (min-width: 992px) {
    .grid-item-triple {
      width: calc(((100% - 60px) / 5) * 3 + 30px) !important;
    }
  }
  @media (min-width: 1200px) {
    .grid-item-triple {
      width: calc(((100% - 90px) / 7) * 3 + 30px) !important;
    }
  }
  .masonry-card {
    cursor: pointer;
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.25s ease;
  }
  .masonry-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
    border-color: var(--bs-purple) !important;
  }
  .masonry-card img {
    transition: filter 0.25s ease;
  }
  .masonry-card:hover img {
    filter: brightness(0.85);
  }
  .masonry-overlay {
    opacity: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0) 60%, rgba(0,0,0,0.6) 100%);
    transition: opacity 0.25s ease;
  }
  .masonry-card:hover .masonry-overlay {
    opacity: 1;
  }
  .lightbox-external-link {
    color: rgba(255, 255, 255, 0.95) !important;
