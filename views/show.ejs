    transform: rotate(0deg);
    display: inline-block;
  }
  .accordion-toggle-arrow[aria-expanded="true"] .collapse-icon {
    transform: rotate(180deg);
  }
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

