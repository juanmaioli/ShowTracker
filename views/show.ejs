<%- include('partials/header') %>

<% if (show.background) { %>
<!-- Cabecera Premium con Background y Efecto Blur -->
<div class="position-relative rounded-4 overflow-hidden mb-5 shadow border border-secondary border-opacity-10" style="min-height: 380px;">
  <!-- Imagen de fondo -->
  <div class="position-absolute top-0 start-0 w-100 h-100" style="background-image: url('<%= show.background %>'); background-size: cover; background-position: center; filter: blur(6px) brightness(0.4); transform: scale(1.03); z-index: 1;"></div>
  
  <!-- Contenido superior -->
  <div class="position-relative p-4 p-md-5 d-flex flex-column justify-content-between h-100" style="z-index: 2; min-height: 380px; background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.3) 100%);">
    <div class="row g-4 align-items-center flex-grow-1">
      <!-- Poster -->
      <div class="col-md-4 col-lg-3 text-center text-md-start">
        <img src="<%= show.image %>" class="img-fluid rounded-3 shadow-lg border border-secondary border-opacity-25 poster-image" style="max-height: 280px; aspect-ratio: 2/3; object-fit: cover;" alt="<%= show.name %>" onerror="this.src='/img/placeholder.svg';">
        
        <form action="/series/eliminar" method="POST" class="mt-3 mb-0" onsubmit="return confirm('¿De verdad querés dejar de seguir esta serie? Se borrará todo el historial.');">
          <input type="hidden" name="seriesId" value="<%= show.id %>">
          <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill py-1">
            🗑️ Dejar de seguir
          </button>
        </form>
      </div>
      <!-- Detalles -->
      <div class="col-md-8 col-lg-9 text-white">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
          <h1 class="fw-black mb-0 display-5 text-shadow"><%= show.name %><%= show.first_air_year ? ` (${show.first_air_year})` : '' %></h1>
          <button class="btn btn-outline-light btn-sm rounded-pill px-3 d-flex align-items-center gap-1 btn-update-series-action shadow-sm" data-series-id="<%= show.id %>" style="transition: all 0.3s ease;">
            <span class="update-icon">🔄</span>
            <span class="update-text">Actualizar</span>
          </button>
          <a href="https://www.justwatch.com/ar/buscar?q=<%= encodeURIComponent(show.name) %>" target="_blank" class="btn btn-outline-warning btn-sm rounded-pill px-3 d-flex align-items-center gap-1 shadow-sm" style="transition: all 0.3s ease;" title="Buscar en JustWatch Argentina">
            <span>🔍</span>
            <span>JustWatch</span>
          </a>
          <% 
            let statusText = show.status;
            let statusClass = 'bg-primary bg-opacity-75';
            if (show.status && show.status.toLowerCase() === 'continuing') {
              statusText = 'En emisión';
              statusClass = 'bg-success text-white';
            } else if (show.status && show.status.toLowerCase() === 'ended') {
              statusText = 'Terminada';
              statusClass = 'bg-danger text-white';
            }
          %>
          <span class="badge <%= statusClass %> rounded-pill"><%= statusText %></span>
          <span class="badge bg-purple text-white rounded-pill series-score-badge">⭐ <%= show.score ? show.score.toFixed(1) : '0.0' %></span>
        </div>
        <p class="text-white-50 small mb-3">ID de TheTVDB: <a href="https://thetvdb.com/series/<%= show.slug %>" target="_blank" class="text-white-50 text-decoration-underline"><%= show.id %></a></p>
        <p class="lead text-light text-shadow opacity-90 mb-0"><%= show.overview %></p>
      </div>
    </div>

    <!-- Barra de progreso dentro del banner con botón para marcar todo -->
    <div class="mt-4 bg-black bg-opacity-50 p-3 rounded-3 border border-secondary border-opacity-25">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="fs-6 fw-bold text-white mb-0">Progreso de la Serie</h5>
        <button class="btn btn-sm <%= progress.total === progress.watched ? 'btn-outline-warning' : 'btn-outline-success' %> rounded-pill py-0 px-2 btn-series-toggle" 
                data-series-id="<%= show.id %>" 
                data-watched="<%= progress.total === progress.watched ? 'true' : 'false' %>">
          <%= progress.total === progress.watched ? 'Desmarcar toda la serie' : 'Completar toda la serie' %>
        </button>
      </div>
      <div class="d-flex align-items-center gap-3">
        <div class="progress flex-grow-1 rounded-pill" style="height: 10px;">
          <div id="series-progress-bar" class="progress-bar bg-success rounded-pill" role="progressbar" style="width: <%= progress.percentage %>%" aria-valuenow="<%= progress.percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <span id="series-progress-text" class="fw-semibold text-success small">
          <%= progress.watched %> / <%= progress.total %> (<%= progress.percentage %>%)
        </span>
      </div>
    </div>
  </div>
</div>
<% } else { %>
<!-- Cabecera estándar sin Background -->
<div class="row g-4 mb-5">
  <!-- Poster de la serie -->
  <div class="col-md-4 col-lg-3 text-center text-md-start">
    <div class="card glass-card border-0 rounded-4 overflow-hidden shadow">
      <img src="<%= show.image %>" class="w-100 object-fit-cover" alt="<%= show.name %>" onerror="this.src='/img/placeholder.svg';">
    </div>
    
    <form action="/series/eliminar" method="POST" class="mt-3" onsubmit="return confirm('¿De verdad querés dejar de seguir esta serie? Se borrará todo el historial.');">
      <input type="hidden" name="seriesId" value="<%= show.id %>">
      <button type="submit" class="btn btn-outline-danger w-100 rounded-pill">
        🗑️ Dejar de seguir serie
      </button>
    </form>
  </div>

  <!-- Detalles de la serie -->
  <div class="col-md-8 col-lg-9">
    <div class="d-flex flex-column h-100 justify-content-between">
      <div>
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
          <h1 class="fw-black mb-0 text-gradient"><%= show.name %><%= show.first_air_year ? ` (${show.first_air_year})` : '' %></h1>
          <button class="btn btn-outline-primary btn-sm rounded-pill px-3 d-flex align-items-center gap-1 btn-update-series-action shadow-sm" data-series-id="<%= show.id %>" style="transition: all 0.3s ease;">
            <span class="update-icon">🔄</span>
            <span class="update-text">Actualizar</span>
          </button>
          <a href="https://www.justwatch.com/ar/buscar?q=<%= encodeURIComponent(show.name) %>" target="_blank" class="btn btn-outline-warning btn-sm rounded-pill px-3 d-flex align-items-center gap-1 shadow-sm" style="transition: all 0.3s ease;" title="Buscar en JustWatch Argentina">
            <span>🔍</span>
            <span>JustWatch</span>
          </a>
          <% 
            let statusTextStr = show.status;
            let statusClassStr = 'bg-primary bg-opacity-25 text-primary-emphasis';
            if (show.status && show.status.toLowerCase() === 'continuing') {
              statusTextStr = 'En emisión';
              statusClassStr = 'bg-success text-white';
            } else if (show.status && show.status.toLowerCase() === 'ended') {
              statusTextStr = 'Terminada';
              statusClassStr = 'bg-danger text-white';
            }
          %>
          <span class="badge <%= statusClassStr %> rounded-pill"><%= statusTextStr %></span>
          <span class="badge text-purple rounded-pill series-score-badge" style="background-color: var(--bs-purple-alt) !important;">⭐ <%= show.score ? show.score.toFixed(1) : '0.0' %></span>
        </div>
        <p class="small">ID de TheTVDB: <a href="https://thetvdb.com/series/<%= show.slug %>" target="_blank" class="text-decoration-underline"><%= show.id %></a></p>
        <p class="lead text-secondary-emphasis"><%= show.overview %></p>
      </div>

      <!-- Barra de progreso general con botón para marcar todo -->
      <div class="card glass-card p-3 rounded-3 mt-4 border-secondary border-opacity-25 shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h5 class="fs-6 fw-bold mb-0">Progreso de la Serie</h5>
          <button class="btn btn-sm <%= progress.total === progress.watched ? 'btn-outline-warning' : 'btn-outline-success' %> rounded-pill py-0 px-2 btn-series-toggle" 
                  data-series-id="<%= show.id %>" 
                  data-watched="<%= progress.total === progress.watched ? 'true' : 'false' %>">
            <%= progress.total === progress.watched ? 'Desmarcar toda la serie' : 'Completar toda la serie' %>
          </button>
        </div>
        <div class="d-flex align-items-center gap-3">
          <div class="progress flex-grow-1 rounded-pill" style="height: 10px;">
            <div id="series-progress-bar" class="progress-bar bg-success rounded-pill" role="progressbar" style="width: <%= progress.percentage %>%" aria-valuenow="<%= progress.percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <span id="series-progress-text" class="fw-semibold text-success small">
            <%= progress.watched %> / <%= progress.total %> (<%= progress.percentage %>%)
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if (cast && cast.length > 0) { %>
<!-- Elenco Principal -->
