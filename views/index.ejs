<%- include('partials/header') %>

<!-- Resumen y Progreso General -->
<div class="row mb-5">
  <div class="col-12">
    <div class="card glass-card p-4 shadow rounded-4 text-center text-md-start">
      <div class="row align-items-center">
        <div class="col-md-8 mb-3 mb-md-0">
          <h1 class="fw-black mb-2 text-gradient">📺 Mi Biblioteca</h1>
          <p class="mb-0">Haciendo seguimiento de <strong><%= stats.totalShows %></strong> series y <strong><%= stats.totalWatched %></strong> / <strong><%= stats.totalEpisodes %></strong> episodios vistos.</p>
        </div>
        <div class="col-md-4 text-md-end">
          <a href="/series/buscar" class="btn btn-primary btn-lg rounded-pill px-4 shadow">
            Buscar Nueva Serie
          </a>
        </div>
      </div>
      
      <% if (stats.totalEpisodes > 0) { %>
        <div class="mt-4">
          <div class="d-flex justify-content-between mb-1 small fw-semibold">
            <span>Progreso General de Visualización</span>
            <span><%= stats.overallProgress %>%</span>
          </div>
          <div class="progress rounded-pill" style="height: 12px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success rounded-pill" role="progressbar" style="width: <%= stats.overallProgress %>%" aria-valuenow="<%= stats.overallProgress %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Listado de Series -->
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div class="d-flex flex-wrap align-items-center gap-3">
    <h2 class="fs-4 fw-bold mb-0 d-flex align-items-center gap-2">
      <span>📂</span> Series en Seguimiento
    </h2>
    <% if (shows.length > 0) { %>
      <!-- Switch de Vista (Tarjetas / Lista) -->
      <div class="btn-group btn-group-sm rounded-pill overflow-hidden border border-secondary border-opacity-25 bg-dark bg-opacity-30 p-0.5" role="group" id="view-mode-group">
        <input type="radio" class="btn-check" name="viewMode" id="viewModeGrid" autocomplete="off" checked>
        <label class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1 border-0" for="viewModeGrid" style="font-size: 0.75rem; cursor: pointer;">🎴 Tarjetas</label>
        
        <input type="radio" class="btn-check" name="viewMode" id="viewModeList" autocomplete="off">
        <label class="btn btn-outline-primary btn-sm rounded-pill px-3 py-1 border-0" for="viewModeList" style="font-size: 0.75rem; cursor: pointer;">📝 Lista</label>
      </div>
    <% } %>
  </div>
  <% if (shows.length > 0) { %>
    <button id="toggle-completed-btn" class="btn btn-outline-secondary btn-sm rounded-pill px-3 d-flex align-items-center gap-1" style="transition: all 0.3s ease;">
      <span id="toggle-completed-icon">👁️</span>
      <span id="toggle-completed-text">Ocultar completadas</span>
    </button>
  <% } %>
</div>

<% if (shows.length === 0) { %>
  <div class="row my-5">
    <div class="col-12 text-center py-5">
      <div class="display-3 mb-3">🔍</div>
      <h3>¿No sabés qué ver?</h3>
      <p class="mb-4">Comenzá a seguir tu primera serie haciendo una búsqueda en TheTVDB.</p>
      <a href="/series/buscar" class="btn btn-outline-primary rounded-pill px-4">Buscar Series</a>
    </div>
  </div>
<% } else { %>
  <!-- Contenedor Vista Tarjetas (Grid) -->
  <div id="view-grid-container" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
    <% shows.forEach(show => { %>
      <% const percentage = show.total_episodes > 0 ? Math.round((show.watched_episodes / show.total_episodes) * 100) : 0; %>
      <div class="col" data-completed="<%= percentage === 100 %>">
        <div class="card h-100 glass-card shadow-sm border-0 rounded-4 overflow-hidden d-flex flex-column">
          <!-- Poster (Clickable al detalle) -->
          <a href="/series/<%= show.id %>" class="d-block text-decoration-none">
            <div class="poster-container" style="aspect-ratio: 2/3;">
              <img src="<%= show.image %>" class="w-100 h-100 object-fit-cover poster-image" alt="<%= show.name %>" onerror="this.src='/img/placeholder.svg';">
              
              <!-- Triángulo púrpura en la esquina superior izquierda -->
              <div class="position-absolute top-0 start-0" style="width: 56px; height: 56px; background: linear-gradient(to bottom right, var(--bs-purple) 50%, transparent 50%); z-index: 1;" title="Calificación propia"></div>
              
              <!-- Calificación propia del usuario sobre el triángulo -->
              <span class="position-absolute text-white fw-bold d-flex align-items-center gap-1" style="top: 8px; left: 4px; font-size: 0.75rem; z-index: 2; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); transform: rotate(-45deg);" title="Tu calificación: <%= show.user_score.toFixed(1) %>">
                ⭐<%= show.user_score.toFixed(1) %>
              </span>

              <% if (percentage === 100) { %>
                <!-- Triángulo verde en la esquina superior derecha -->
                <div class="position-absolute top-0 end-0" style="width: 64px; height: 64px; background: linear-gradient(to bottom left, var(--bs-success) 50%, transparent 50%); z-index: 2;" title="Serie completada"></div>
                
                <!-- Texto 100% inclinado sobre el triángulo -->
                <span class="position-absolute text-white fw-bold" style="top: 8px; right: 4px; font-size: 0.75rem; z-index: 3; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); transform: rotate(45deg);" title="Serie completada al 100%">
                  100%
                </span>
              <% } %>
            </div>
          </a>
          
          <!-- Contenido -->
          <div class="card-body p-2 d-flex flex-column flex-grow-1">
            <h3 class="card-title fs-6 fw-bold text-truncate mb-1"><%= show.name %><%= show.first_air_year ? ` (${show.first_air_year})` : '' %></h3>
            <% 
              let statusText = show.status;
              let statusClass = 'bg-secondary bg-opacity-25 text-secondary-emphasis';
              if (show.status && show.status.toLowerCase() === 'continuing') {
                statusText = 'En emisión';
                statusClass = 'bg-success text-white';
              } else if (show.status && show.status.toLowerCase() === 'ended') {
                statusText = 'Terminada';
                statusClass = 'bg-danger text-white';
              }
            %>
            <span class="badge <%= statusClass %> align-self-start mb-2 rounded-pill" style="font-size: 0.7rem;">
              <%= statusText %>
            </span>
            
            <div class="mt-auto">
              <!-- Progreso de la serie -->
              <div class="d-flex justify-content-between mb-1 small">
                <span><%= show.watched_episodes %> / <%= show.total_episodes %> epis.</span>
                <span><%= percentage %>%</span>
              </div>
              <div class="progress mb-3" style="height: 6px;">
                <div class="progress-bar <%= percentage === 100 ? 'bg-success' : 'bg-primary' %> rounded" role="progressbar" style="width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
              
              <div class="d-flex gap-2">
                <a href="/series/<%= show.id %>" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1">Ver detalles</a>
                <form action="/series/eliminar" method="POST" onsubmit="return confirm('¿Seguro querés dejar de seguir esta serie? Se perderá el historial de vistos.');">
                  <input type="hidden" name="seriesId" value="<%= show.id %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle px-2" title="Dejar de seguir">
                    🗑️
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Vista de Lista Compacta -->
  <div id="view-list-container" class="d-none">
    <div class="card glass-card p-3 shadow rounded-4 border-0">
      <div class="table-responsive">
        <table class="table table-dark table-hover table-borderless align-middle mb-0" style="--bs-table-bg: transparent;">
          <thead>
            <tr class="text-white-50 border-bottom border-secondary border-opacity-25" style="font-size: 0.8rem;">
              <th scope="col" style="width: 60px;">Póster</th>
              <th scope="col">Nombre</th>
              <th scope="col" style="width: 100px;">Calificación</th>
              <th scope="col" style="width: 130px;">Estado</th>
              <th scope="col" style="width: 220px;">Progreso</th>
              <th scope="col" class="text-end" style="width: 150px;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% shows.forEach(show => { %>
              <% const percentage = show.total_episodes > 0 ? Math.round((show.watched_episodes / show.total_episodes) * 100) : 0; %>
              <tr data-completed="<%= percentage === 100 %>" class="border-bottom border-secondary border-opacity-10 py-2">
                <!-- Póster -->
                <td>
                  <a href="/series/<%= show.id %>">
                    <img src="<%= show.image %>" class="rounded-circle object-fit-cover shadow border border-secondary border-opacity-25" alt="<%= show.name %>" style="width: 40px; height: 40px;" onerror="this.src='/img/placeholder.svg';">
                  </a>
                </td>
                
                <!-- Nombre y Año -->
                <td>
                  <h4 class="fs-6 fw-bold mb-0">
                    <a href="/series/<%= show.id %>" class="text-white text-decoration-none" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                      <%= show.name %><%= show.first_air_year ? ` (${show.first_air_year})` : '' %>
                    </a>
                  </h4>
                </td>
                
                <!-- Calificación Propia -->
                <td>
                  <span class="fw-semibold text-purple">
                    ⭐<%= show.user_score.toFixed(1) %>
                  </span>
                </td>
                
                <!-- Estado -->
                <td>
                  <% 
                    let statusText = show.status;
                    let statusClass = 'bg-secondary bg-opacity-25 text-secondary-emphasis';
                    if (show.status && show.status.toLowerCase() === 'continuing') {
                      statusText = 'En emisión';
                      statusClass = 'bg-success text-white';
                    } else if (show.status && show.status.toLowerCase() === 'ended') {
                      statusText = 'Terminada';
                      statusClass = 'bg-danger text-white';
                    }
                  %>
                  <span class="badge <%= statusClass %> rounded-pill" style="font-size: 0.7rem;">
                    <%= statusText %>
                  </span>
                </td>
                
                <!-- Progreso -->
                <td>
                  <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                    <span class="text-white-50"><%= show.watched_episodes %> / <%= show.total_episodes %> epis.</span>
                    <span class="<%= percentage === 100 ? 'text-success' : 'text-primary' %> fw-bold"><%= percentage %>%</span>
                  </div>
                  <div class="progress" style="height: 5px;">
                    <div class="progress-bar <%= percentage === 100 ? 'bg-success' : 'bg-primary' %> rounded" role="progressbar" style="width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                </td>
                
                <!-- Acciones -->
                <td class="text-end">
                  <div class="d-inline-flex gap-2">
                    <a href="/series/<%= show.id %>" class="btn btn-outline-primary btn-sm rounded-pill px-3" style="font-size: 0.75rem;">Ver</a>
                    <form action="/series/eliminar" method="POST" onsubmit="return confirm('¿Seguro querés dejar de seguir esta serie? Se perderá el historial de vistos.');" class="mb-0">
                      <input type="hidden" name="seriesId" value="<%= show.id %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle px-2" title="Dejar de seguir" style="font-size: 0.75rem; width: 28px; height: 28px; padding: 0; line-height: 28px;">
                        🗑️
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% } %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('toggle-completed-btn');
    const viewGridBtn = document.getElementById('viewModeGrid');
    const viewListBtn = document.getElementById('viewModeList');
    const gridContainer = document.getElementById('view-grid-container');
    const listContainer = document.getElementById('view-list-container');
    
    // Cargar preferencia de modo de vista
    let currentViewMode = localStorage.getItem('showtracker_view_mode') || 'grid';
    
    function applyViewMode() {
      if (!gridContainer || !listContainer) return;
      if (currentViewMode === 'list') {
        gridContainer.classList.add('d-none');
        listContainer.classList.remove('d-none');
        if (viewListBtn) viewListBtn.checked = true;
      } else {
        gridContainer.classList.remove('d-none');
        listContainer.classList.add('d-none');
        if (viewGridBtn) viewGridBtn.checked = true;
      }
    }
    
    if (viewGridBtn && viewListBtn) {
      applyViewMode();
      viewGridBtn.addEventListener('change', () => {
        currentViewMode = 'grid';
        localStorage.setItem('showtracker_view_mode', 'grid');
        applyViewMode();
      });
      viewListBtn.addEventListener('change', () => {
        currentViewMode = 'list';
        localStorage.setItem('showtracker_view_mode', 'list');
        applyViewMode();
      });
    }

    if (toggleBtn) {
      const btnText = document.getElementById('toggle-completed-text');
      const btnIcon = document.getElementById('toggle-completed-icon');
      
      // Cargar preferencia guardada en localStorage
      let hideCompleted = localStorage.getItem('hideCompletedSeries') === 'true';

      function applyFilter() {
        const completedElements = document.querySelectorAll('[data-completed="true"]');
        completedElements.forEach(el => {
          if (hideCompleted) {
            el.classList.add('d-none');
          } else {
            el.classList.remove('d-none');
          }
        });

        if (hideCompleted) {
          btnText.innerText = 'Mostrar completadas';
          btnIcon.innerText = '👁️‍🗨️';
          toggleBtn.classList.remove('btn-outline-secondary');
          toggleBtn.classList.add('btn-success');
        } else {
          btnText.innerText = 'Ocultar completadas';
          btnIcon.innerText = '👁';
          toggleBtn.classList.add('btn-outline-secondary');
          toggleBtn.classList.remove('btn-success');
        }
      }

      // Aplicar filtro inicial
      applyFilter();

      toggleBtn.addEventListener('click', () => {
        hideCompleted = !hideCompleted;
        localStorage.setItem('hideCompletedSeries', hideCompleted);
        applyFilter();
      });
    }
  });
</script>

<%- include('partials/footer') %>
