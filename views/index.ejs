<%- include('partials/header') %>

<!-- Resumen y Progreso General -->
<div class="row mb-5">
  <div class="col-12">
    <div class="card glass-card p-4 shadow rounded-4 text-center text-md-start">
      <div class="row align-items-center">
        <div class="col-md-8 mb-3 mb-md-0">
          <h1 class="fw-black mb-2 text-gradient">📺 Mi Biblioteca</h1>
          <p class="text-secondary mb-0">Haciendo seguimiento de <strong><%= stats.totalShows %></strong> series y <strong><%= stats.totalWatched %></strong> / <strong><%= stats.totalEpisodes %></strong> episodios vistos.</p>
        </div>
        <div class="col-md-4 text-md-end">
          <a href="/series/buscar" class="btn btn-primary btn-lg rounded-pill px-4 shadow">
            Buscar Nueva Serie
          </a>
        </div>
      </div>
      
      <% if (stats.totalEpisodes > 0) { %>
        <div class="mt-4">
          <div class="d-flex justify-content-between mb-1 small fw-semibold text-secondary">
            <span>Progreso General de Visualización</span>
            <span><%= stats.overallProgress %>%</span>
          </div>
          <div class="progress rounded-pill" style="height: 12px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success rounded-pill" role="progressbar" style="width: <%= stats.overallProgress %>%" aria-valuenow="<%= stats.overallProgress %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Listado de Series -->
<h2 class="fs-4 fw-bold mb-4 d-flex align-items-center gap-2">
  <span>📂</span> Series en Seguimiento
</h2>

<% if (shows.length === 0) { %>
  <div class="row my-5">
    <div class="col-12 text-center py-5">
      <div class="display-3 text-secondary mb-3">🔍</div>
      <h3>¿No sabés qué ver?</h3>
      <p class="text-secondary mb-4">Comenzá a seguir tu primera serie haciendo una búsqueda en TheTVDB.</p>
      <a href="/series/buscar" class="btn btn-outline-primary rounded-pill px-4">Buscar Series</a>
    </div>
  </div>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    <% shows.forEach(show => { %>
      <div class="col">
        <div class="card h-100 glass-card shadow-sm border-0 rounded-4 overflow-hidden d-flex flex-column">
          <!-- Poster -->
          <div class="poster-container" style="aspect-ratio: 2/3;">
            <img src="<%= show.image %>" class="w-100 h-100 object-fit-cover poster-image" alt="<%= show.name %>" onerror="this.src='/img/placeholder.svg';">
            <span class="position-absolute top-3 end-3 badge bg-dark bg-opacity-75 rounded-pill border border-secondary border-opacity-50">
              ⭐ <%= show.score ? show.score.toFixed(1) : '0.0' %>
            </span>
          </div>
          
          <!-- Contenido -->
          <div class="card-body p-3 d-flex flex-column flex-grow-1">
            <h3 class="card-title fs-5 fw-bold text-truncate mb-1"><%= show.name %></h3>
            <span class="badge bg-secondary bg-opacity-25 text-secondary-emphasis align-self-start mb-3 rounded-pill">
              <%= show.status %>
            </span>
            
            <div class="mt-auto">
              <!-- Progreso de la serie -->
              <% const percentage = show.total_episodes > 0 ? Math.round((show.watched_episodes / show.total_episodes) * 100) : 0; %>
              <div class="d-flex justify-content-between mb-1 small text-secondary">
                <span><%= show.watched_episodes %> / <%= show.total_episodes %> epis.</span>
                <span><%= percentage %>%</span>
              </div>
              <div class="progress mb-3" style="height: 6px;">
                <div class="progress-bar bg-primary rounded" role="progressbar" style="width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
              
              <div class="d-flex gap-2">
                <a href="/series/<%= show.id %>" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1">Ver detalles</a>
                <form action="/series/eliminar" method="POST" onsubmit="return confirm('¿Seguro querés dejar de seguir esta serie? Se perderá el historial de vistos.');">
                  <input type="hidden" name="seriesId" value="<%= show.id %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle px-2" title="Dejar de seguir">
                    🗑️
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
