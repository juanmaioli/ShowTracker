<%- include('partials/header') %>

<!-- Estilos para el Abecedario Flotante -->
<style>
  #alphabet-nav {
    max-height: 90vh;
    overflow-y: auto;
    scrollbar-width: none; /* Firefox */
  }
  #alphabet-nav::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }
  .alphabet-link {
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: 700;
    border-radius: 50%;
    color: inherit;
    transition: all 0.15s ease;
    border: none;
    background: transparent;
    padding: 0;
    line-height: 1;
  }
  .alphabet-link:hover:not(.disabled) {
    background-color: var(--bs-purple);
    color: #fff !important;
    transform: scale(1.15);
  }
  .alphabet-link.disabled {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Separador de cuadrícula: de alto igual a las tarjetas, pero la mitad de angosto */
  .separator-col {
    flex: 0 0 auto !important;
    width: 25% !important; /* Mobile (mitad de 50%) */
  }
  @media (min-width: 576px) {
    .separator-col {
      width: 16.66667% !important; /* sm (mitad de 33.3%) */
    }
  }
  @media (min-width: 768px) {
    .separator-col {
      width: 12.5% !important; /* md (mitad de 25%) */
    }
  }
  @media (min-width: 992px) {
    .separator-col {
      width: 8.33333% !important; /* lg (mitad de 16.6%) */
    }
  }
</style>

<% if (shows.length > 0) { %>
  <!-- Navegación Alfabética Lateral (Index) -->
  <div id="alphabet-nav" class="d-none d-md-flex flex-column position-fixed end-0 top-50 translate-middle-y me-2 p-1.5 glass-card rounded-pill shadow" style="z-index: 1040; gap: 2px;">
    <!-- Se genera dinámicamente con JS -->
  </div>
<% } %>

<!-- Resumen y Progreso General -->
<div class="row mb-3">
  <div class="col-12">
    <div class="card glass-card p-3 shadow rounded-4 text-center text-md-start">
      <div class="row align-items-center">
        <div class="col-md-4 mb-2 mb-md-0">
          <h1 class="fw-black fs-3 mb-1 text-gradient">📺 Mi Biblioteca</h1>
          <p class="mb-0 small">Haciendo seguimiento de <strong><%= stats.totalShows %></strong> series y <strong><%= stats.totalWatched %></strong> / <strong><%= stats.totalEpisodes %></strong> vistos.</p>
        </div>
        <div class="col-md-8 text-md-end">
      <% if (stats.totalEpisodes > 0) { %>
        <div class="mt-3">
          <div class="d-flex justify-content-between mb-1 small fw-semibold" style="font-size: 0.8rem;">
            <span>Progreso General de Visualización</span>
            <span><%= stats.overallProgress %>%</span>
          </div>
          <div class="progress rounded-pill" style="height: 8px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success rounded-pill" role="progressbar" style="width: <%= stats.overallProgress %>%" aria-valuenow="<%= stats.overallProgress %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
        </div>
      <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Listado de Series -->
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div class="d-flex flex-wrap align-items-center gap-3">
    <h2 class="fs-4 fw-bold mb-0 d-flex align-items-center gap-2">
      <span>📂</span> Series en Seguimiento
    </h2>
    <% if (shows.length > 0) { %>
      <!-- Switch de Vista (Tarjetas / Lista) -->
      <div class="btn-group btn-group rounded-pill overflow-hidden border border-secondary border-opacity-25 bg-dark bg-opacity-30 p-0.5" role="group" id="view-mode-group">
        <input type="radio" class="btn-check" name="viewMode" id="viewModeGrid" autocomplete="off" checked>
        <label class="btn btn-outline-primary rounded-pill px-3 py-1 border-0" for="viewModeGrid" style="font-size: 0.75rem; cursor: pointer;" title="Vista en Tarjetas">🎴</label>
        
        <input type="radio" class="btn-check" name="viewMode" id="viewModeList" autocomplete="off">
        <label class="btn btn-outline-primary rounded-pill px-3 py-1 border-0" for="viewModeList" style="font-size: 0.75rem; cursor: pointer;" title="Vista en Lista">📝</label>
      </div>

      <!-- Buscador por Nombre -->
      <div class="position-relative ms-0 ms-sm-2" style="min-width: 180px;">
        <input type="text" id="search-shows-input" class="form-control form-control-sm rounded-pill bg-body-tertiary border-secondary border-opacity-25 ps-3 pe-4" placeholder="Buscar por nombre..." title="Filtrar por nombre" style="font-size: 0.75rem; height: 31px; width: 100%;">
        <span class="position-absolute end-0 top-50 translate-middle-y pe-3 text-secondary small" style="pointer-events: none; font-size: 0.75rem;">🔍</span>
      </div>
    <% } %>
  </div>
  <% if (shows.length > 0) { %>
    <div class="d-flex gap-2">
      <button id="toggle-abandoned-btn" class="btn btn-outline-secondary rounded-pill px-3 d-flex align-items-center gap-1" style="transition: all 0.3s ease;" title="Mostrar solo abandonadas / Mostrar todas">
        <span id="toggle-abandoned-icon">🥀</span>
        <!-- <span id="toggle-abandoned-text">Solo abandonadas</span> -->
      </button>
      <button id="toggle-ended-btn" class="btn btn-outline-secondary rounded-pill px-3 d-flex align-items-center gap-1" style="transition: all 0.3s ease;" title="Ocultar/Mostrar Terminadas">
        <span id="toggle-ended-icon">🎬</span>
        <!-- <span id="toggle-ended-text"></span> -->
      </button>
      <button id="toggle-completed-btn" class="btn btn-outline-secondary rounded-pill px-3 d-flex align-items-center gap-1" style="transition: all 0.3s ease;">
        <span id="toggle-completed-icon">👁️</span>
        <!-- <span id="toggle-completed-text">Ocultar completadas</span> -->
      </button>
    </div>
  <% } %>
</div>

<% if (shows.length === 0) { %>
  <div class="row my-5">
    <div class="col-12 text-center py-5">
      <div class="display-3 mb-3">🔍</div>
      <h3>¿No sabés qué ver?</h3>
      <p class="mb-4">Comenzá a seguir tu primera serie haciendo una búsqueda en TheTVDB.</p>
      <a href="/series/buscar" class="btn btn-outline-primary rounded-pill px-4">Buscar Series</a>
    </div>
  </div>
<% } else { %>
  <!-- Contenedor Vista Tarjetas (Grid) -->
  <div id="view-grid-container" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
    <% let lastInitialGrid = ''; %>
    <% shows.forEach(show => { %>
      <% 
        let firstChar = show.name.charAt(0).toUpperCase();
        let normalizedChar = firstChar;
        if (firstChar !== 'Ñ') {
          normalizedChar = firstChar.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        }
        let currentInitial = /^[0-9\W]/.test(normalizedChar) ? '#' : normalizedChar;
        if (currentInitial !== lastInitialGrid) { 
          lastInitialGrid = currentInitial;
      %>
        <!-- Salto de línea para forzar inicio de fila -->
        <div class="w-100 separator-break" data-letter="<%= currentInitial.toLowerCase() %>"></div>
        <!-- Separador de Letra (Grid) -->
        <div class="col separator-col" data-letter="<%= currentInitial.toLowerCase() %>">
          <div class="card h-100 glass-card shadow-sm border-0 rounded-4 overflow-hidden d-flex align-items-center justify-content-center bg-purple bg-opacity-10" style="border: 2px dashed var(--bs-purple) !important;">
            <span class="display-3 fw-black text-gradient opacity-75"><%= currentInitial %></span>
          </div>
        </div>
      <% } %>
      <% const percentage = show.total_episodes > 0 ? Math.round((show.watched_episodes / show.total_episodes) * 100) : 0; %>
      <div class="col" data-completed="<%= percentage === 100 %>" data-name="<%= show.name.toLowerCase() %>" data-score="<%= show.user_score %>" data-status="<%= (show.status || '').toLowerCase() %>" data-abandoned="<%= percentage < 100 && show.status && show.status.toLowerCase() === 'ended' %>">
        <div class="card h-100 glass-card shadow-sm border-0 rounded-4 overflow-hidden d-flex flex-column">
          <!-- Poster (Clickable al detalle) -->
          <a href="/series/<%= show.id %>" class="d-block text-decoration-none">
            <div class="poster-container" style="aspect-ratio: 2/3;">
              <img src="<%= show.image %>" class="w-100 h-100 object-fit-cover poster-image" alt="<%= show.name %>" onerror="this.src='/img/placeholder.svg';">
              
              <!-- Triángulo púrpura en la esquina superior izquierda -->
              <div class="position-absolute top-0 start-0" style="width: 56px; height: 56px; background: linear-gradient(to bottom right, var(--bs-purple) 50%, transparent 50%); z-index: 1;" title="Calificación propia"></div>
              
              <!-- Calificación propia del usuario sobre el triángulo -->
              <span class="position-absolute text-white fw-bold d-flex align-items-center gap-1" style="top: 8px; left: 4px; font-size: 0.75rem; z-index: 2; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); transform: rotate(-45deg);" title="Tu calificación: <%= show.user_score.toFixed(1) %>">
                ⭐<%= show.user_score.toFixed(1) %>
              </span>

              <% if (percentage === 100) { %>
                <!-- Triángulo verde en la esquina superior derecha -->
                <div class="position-absolute top-0 end-0" style="width: 64px; height: 64px; background: linear-gradient(to bottom left, var(--bs-success) 50%, transparent 50%); z-index: 2;" title="Serie completada"></div>
                
                <!-- Texto 100% inclinado sobre el triángulo -->
                <span class="position-absolute text-white fw-bold" style="top: 8px; right: 4px; font-size: 0.75rem; z-index: 3; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); transform: rotate(45deg);" title="Serie completada al 100%">
                  100%
                </span>
              <% } %>
            </div>
          </a>
          
          <!-- Contenido -->
          <div class="card-body p-2 d-flex flex-column flex-grow-1">
            <h3 class="card-title fs-6 fw-bold text-truncate mb-1"><%= show.name %><%= show.first_air_year ? ` (${show.first_air_year})` : '' %></h3>
            <% 
              let statusText = show.status;
              let statusClass = 'bg-secondary bg-opacity-25 text-secondary-emphasis';
              if (show.status && show.status.toLowerCase() === 'continuing') {
                statusText = 'En emisión';
                statusClass = 'bg-success text-white';
              } else if (show.status && show.status.toLowerCase() === 'ended') {
                statusText = 'Terminada';
                statusClass = 'bg-danger text-white';
              }
            %>
            <span class="badge <%= statusClass %> align-self-start mb-2 rounded-pill" style="font-size: 0.7rem;">
              <%= statusText %>
            </span>
            
            <div class="mt-auto">
              <!-- Progreso de la serie -->
              <div class="d-flex justify-content-between mb-1 small">
                <span><%= show.watched_episodes %> / <%= show.total_episodes %> epis.</span>
                <span><%= percentage %>%</span>
              </div>
              <div class="progress mb-3" style="height: 6px;">
                <div class="progress-bar <%= percentage === 100 ? 'bg-success' : 'bg-primary' %> rounded" role="progressbar" style="width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
              
              <div class="d-flex gap-2">
                <a href="/series/<%= show.id %>" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1">Ver detalles</a>
                <form action="/series/eliminar" method="POST" onsubmit="return confirm('¿Seguro querés dejar de seguir esta serie? Se perderá el historial de vistos.');">
                  <input type="hidden" name="seriesId" value="<%= show.id %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle px-2" title="Dejar de seguir">
                    🗑️
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Vista de Lista Compacta -->
  <div id="view-list-container" class="d-none">
    <div class="card glass-card p-3 shadow rounded-4 border-0">
      <div class="table-responsive">
        <table class="table table-hover table-borderless align-middle mb-0" style="--bs-table-bg: transparent; color: inherit;">
          <thead>
            <tr class="opacity-75 border-bottom border-secondary border-opacity-25" style="font-size: 0.8rem;">
              <th scope="col" style="width: 60px;">Póster</th>
              <th scope="col">Nombre</th>
              <th scope="col" style="width: 100px;">Calificación</th>
              <th scope="col" style="width: 130px;">Estado</th>
              <th scope="col" style="width: 220px;">Progreso</th>
              <th scope="col" class="text-end" style="width: 150px;">Acciones</th>
            </tr>
          </thead>
          <tbody id="view-list-tbody">
            <% let lastInitialList = ''; %>
            <% shows.forEach(show => { %>
              <% 
                let firstChar = show.name.charAt(0).toUpperCase();
                let normalizedChar = firstChar;
                if (firstChar !== 'Ñ') {
                  normalizedChar = firstChar.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
                }
                let currentInitial = /^[0-9\W]/.test(normalizedChar) ? '#' : normalizedChar;
                if (currentInitial !== lastInitialList) { 
                  lastInitialList = currentInitial;
              %>
                <!-- Separador de Letra (Lista) -->
                <tr class="separator-row" data-letter="<%= currentInitial.toLowerCase() %>">
                  <td colspan="6" class="py-3 ps-3 border-bottom border-secondary border-opacity-25 bg-body-secondary bg-opacity-25">
                    <span class="fs-5 fw-black text-gradient"><%= currentInitial %></span>
                  </td>
                </tr>
              <% } %>
              <% const percentage = show.total_episodes > 0 ? Math.round((show.watched_episodes / show.total_episodes) * 100) : 0; %>
              <tr data-completed="<%= percentage === 100 %>" data-name="<%= show.name.toLowerCase() %>" data-score="<%= show.user_score %>" data-status="<%= (show.status || '').toLowerCase() %>" data-abandoned="<%= percentage < 100 && show.status && show.status.toLowerCase() === 'ended' %>" class="border-bottom border-secondary border-opacity-10 py-2">
                <!-- Póster -->
                <td>
                  <a href="/series/<%= show.id %>">
                    <img src="<%= show.image %>" class="rounded-circle object-fit-cover shadow border border-secondary border-opacity-25" alt="<%= show.name %>" style="width: 40px; height: 40px;" onerror="this.src='/img/placeholder.svg';">
                  </a>
                </td>
                
                <!-- Nombre y Año -->
                <td>
                  <h4 class="fs-6 fw-bold mb-0">
                    <a href="/series/<%= show.id %>" class="text-reset text-decoration-none" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                      <%= show.name %><%= show.first_air_year ? ` (${show.first_air_year})` : '' %>
                    </a>
                  </h4>
                </td>
                
                <!-- Calificación Propia -->
                <td>
                  <span class="fw-semibold text-purple">
                    ⭐<%= show.user_score.toFixed(1) %>
                  </span>
                </td>
                
                <!-- Estado -->
                <td>
                  <% 
                    let statusText = show.status;
                    let statusClass = 'bg-secondary bg-opacity-25 text-secondary-emphasis';
                    if (show.status && show.status.toLowerCase() === 'continuing') {
                      statusText = 'En emisión';
                      statusClass = 'bg-success text-white';
                    } else if (show.status && show.status.toLowerCase() === 'ended') {
                      statusText = 'Terminada';
                      statusClass = 'bg-danger text-white';
                    }
                  %>
                  <span class="badge <%= statusClass %> rounded-pill" style="font-size: 0.7rem;">
                    <%= statusText %>
                  </span>
                </td>
                
                <!-- Progreso -->
                <td>
                  <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem;">
                    <span class="text-secondary"><%= show.watched_episodes %> / <%= show.total_episodes %> epis.</span>
                    <span class="<%= percentage === 100 ? 'text-success' : 'text-primary' %> fw-bold"><%= percentage %>%</span>
                  </div>
                  <div class="progress" style="height: 5px;">
                    <div class="progress-bar <%= percentage === 100 ? 'bg-success' : 'bg-primary' %> rounded" role="progressbar" style="width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                </td>
                
                <!-- Acciones -->
                <td class="text-end">
                  <div class="d-inline-flex gap-2">
                    <a href="/series/<%= show.id %>" class="btn btn-outline-primary btn-sm rounded-pill px-3" style="font-size: 0.75rem;">Ver</a>
                    <form action="/series/eliminar" method="POST" onsubmit="return confirm('¿Seguro querés dejar de seguir esta serie? Se perderá el historial de vistos.');" class="mb-0">
                      <input type="hidden" name="seriesId" value="<%= show.id %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle px-2" title="Dejar de seguir" style="font-size: 0.75rem; width: 28px; height: 28px; padding: 0; line-height: 28px;">
                        🗑️
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Mensaje de no resultados en búsqueda -->
  <div id="no-search-results-message" class="row my-5 d-none">
    <div class="col-12 text-center py-5">
      <div class="display-4 mb-3">🔍</div>
      <h4>No se encontraron series</h4>
      <p class="text-secondary small">Probá buscando con otro nombre o borrando el filtro.</p>
    </div>
  </div>
<% } %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('toggle-completed-btn');
    const viewGridBtn = document.getElementById('viewModeGrid');
    const viewListBtn = document.getElementById('viewModeList');
    const gridContainer = document.getElementById('view-grid-container');
    const listContainer = document.getElementById('view-list-container');
    
    // Cargar preferencia de modo de vista
    let currentViewMode = localStorage.getItem('showtracker_view_mode') || 'grid';
    
    function applyViewMode() {
      if (!gridContainer || !listContainer) return;
      if (currentViewMode === 'list') {
        gridContainer.classList.add('d-none');
        listContainer.classList.remove('d-none');
        if (viewListBtn) viewListBtn.checked = true;
      } else {
        gridContainer.classList.remove('d-none');
        listContainer.classList.add('d-none');
        if (viewGridBtn) viewGridBtn.checked = true;
      }
    }
    
    if (viewGridBtn && viewListBtn) {
      applyViewMode();
      viewGridBtn.addEventListener('change', () => {
        currentViewMode = 'grid';
        localStorage.setItem('showtracker_view_mode', 'grid');
        applyViewMode();
      });
      viewListBtn.addEventListener('change', () => {
        currentViewMode = 'list';
        localStorage.setItem('showtracker_view_mode', 'list');
        applyViewMode();
      });
    }

    // Nota: Las series se ordenan alfabéticamente de forma predeterminada desde el servidor

    const toggleEndedBtn = document.getElementById('toggle-ended-btn');
    const toggleAbandonedBtn = document.getElementById('toggle-abandoned-btn');
    if (toggleBtn && toggleEndedBtn && toggleAbandonedBtn) {
      // const btnText = document.getElementById('toggle-completed-text');
      const btnIcon = document.getElementById('toggle-completed-icon');
      // const endedBtnText = document.getElementById('toggle-ended-text');
      const endedBtnIcon = document.getElementById('toggle-ended-icon');
      // const abandonedBtnText = document.getElementById('toggle-abandoned-text');
      const abandonedBtnIcon = document.getElementById('toggle-abandoned-icon');
      
      // Cargar preferencias guardadas en localStorage
      let hideCompleted = localStorage.getItem('hideCompletedSeries') === 'true';
      let hideEnded = localStorage.getItem('hideEndedSeries') === 'true';
      let showOnlyAbandoned = localStorage.getItem('showOnlyAbandonedSeries') === 'true';

      const searchInput = document.getElementById('search-shows-input');

      function applyFilters() {
        const allCards = document.querySelectorAll('#view-grid-container > .col:not(.separator-col)');
        const allRows = document.querySelectorAll('#view-list-tbody > tr:not(.separator-row)');
        const searchQuery = searchInput ? searchInput.value.toLowerCase().trim() : '';
        
        const filterItem = (el) => {
          const isCompleted = el.dataset.completed === 'true';
          const isEnded = el.dataset.status === 'ended';
          const isAbandoned = el.dataset.abandoned === 'true';
          const name = el.dataset.name || '';
          
          let shouldHide = false;
          if (showOnlyAbandoned) {
            // Si está activo "Solo abandonadas", se oculta todo lo que no sea abandonado
            shouldHide = !isAbandoned;
          } else {
            // Filtros normales
            shouldHide = (hideCompleted && isCompleted) || (hideEnded && isEnded);
          }
          
          // Filtrar también por nombre si corresponde
          if (!shouldHide && searchQuery !== '') {
            shouldHide = !name.includes(searchQuery);
          }
          
          if (shouldHide) {
            el.classList.add('d-none');
          } else {
            el.classList.remove('d-none');
          }
        };

        allCards.forEach(filterItem);
        allRows.forEach(filterItem);

        // Mostrar/ocultar separadores del Grid y sus saltos de línea según si hay tarjetas visibles
        const gridSeparators = document.querySelectorAll('#view-grid-container > .separator-col');
        gridSeparators.forEach(sep => {
          const letter = sep.dataset.letter;
          const breakDiv = document.querySelector(`#view-grid-container > .separator-break[data-letter="${letter}"]`);
          
          const hasVisible = Array.from(allCards).some(card => {
            if (card.classList.contains('d-none')) return false;
            const firstChar = card.dataset.name.charAt(0);
            let normalizedChar = firstChar;
            if (firstChar !== 'ñ') {
              normalizedChar = firstChar.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            }
            if (letter === '#') {
              return /^[0-9\W]/.test(normalizedChar);
            } else {
              return normalizedChar === letter;
            }
          });
          
          if (hasVisible) {
            sep.classList.remove('d-none');
          } else {
            sep.classList.add('d-none');
            if (breakDiv) breakDiv.classList.add('d-none');
          }
        });

        // Mostrar/ocultar separadores de la Lista según si hay filas visibles
        const listSeparators = document.querySelectorAll('#view-list-tbody > .separator-row');
        listSeparators.forEach(sep => {
          const letter = sep.dataset.letter;
          const hasVisible = Array.from(allRows).some(row => {
            if (row.classList.contains('d-none')) return false;
            const firstChar = row.dataset.name.charAt(0);
            let normalizedChar = firstChar;
            if (firstChar !== 'ñ') {
              normalizedChar = firstChar.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            }
            if (letter === '#') {
              return /^[0-9\W]/.test(normalizedChar);
            } else {
              return normalizedChar === letter;
            }
          });
          if (hasVisible) {
            sep.classList.remove('d-none');
          } else {
            sep.classList.add('d-none');
          }
        });

        // Controlar si se muestran resultados o no
        let visibleCount = 0;
        allCards.forEach(el => {
          if (!el.classList.contains('d-none')) {
            visibleCount++;
          }
        });
        
        const noResultsMsg = document.getElementById('no-search-results-message');
        if (noResultsMsg) {
          if (visibleCount === 0) {
            noResultsMsg.classList.remove('d-none');
          } else {
            noResultsMsg.classList.add('d-none');
          }
        }

        // Actualizar botón de completadas
        if (hideCompleted) {
          // btnText.innerText = 'Mostrar completadas';
          btnIcon.innerText = '👁️‍🗨️';
          toggleBtn.classList.remove('btn-outline-secondary');
          toggleBtn.classList.add('btn-success');
        } else {
          // btnText.innerText = 'Ocultar completadas';
          btnIcon.innerText = '👁';
          toggleBtn.classList.add('btn-outline-secondary');
          toggleBtn.classList.remove('btn-success');
        }

        // Actualizar botón de terminadas
        if (hideEnded) {
          // endedBtnText.innerText = 'Mostrar terminadas';
          endedBtnIcon.innerText = '🎬';
          toggleEndedBtn.classList.remove('btn-outline-secondary');
          toggleEndedBtn.classList.add('btn-danger');
        } else {
          // endedBtnText.innerText = 'Ocultar terminadas';
          endedBtnIcon.innerText = '🎬';
          toggleEndedBtn.classList.add('btn-outline-secondary');
          toggleEndedBtn.classList.remove('btn-danger');
        }

        // Actualizar botón de abandonadas (Filtro exclusivo de "Solo abandonadas")
        if (showOnlyAbandoned) {
          // abandonedBtnText.innerText = 'Mostrar todas';
          abandonedBtnIcon.innerText = '📂';
          toggleAbandonedBtn.classList.remove('btn-outline-secondary');
          toggleAbandonedBtn.classList.add('btn-indigo');
          
          // Desactivar los otros botones ya que el modo exclusivo tiene prioridad
          toggleBtn.disabled = true;
          toggleEndedBtn.disabled = true;
        } else {
          // abandonedBtnText.innerText = 'Solo abandonadas';
          abandonedBtnIcon.innerText = '🥀';
          toggleAbandonedBtn.classList.add('btn-outline-secondary');
          toggleAbandonedBtn.classList.remove('btn-indigo');
          
          toggleBtn.disabled = false;
          toggleEndedBtn.disabled = false;
        }

        // Actualizar navegación alfabética lateral
        if (typeof updateAlphabetNav === 'function') {
          updateAlphabetNav();
        }

        // Ajustar saltos de línea de los separadores del Grid dinámicamente
        if (typeof adjustGridSeparators === 'function') {
          adjustGridSeparators();
        }
      }

      function getColsPerRow() {
        const width = window.innerWidth;
        if (width >= 992) return 6; // lg
        if (width >= 768) return 4; // md
        if (width >= 576) return 3; // sm
        return 2; // xs
      }

      function adjustGridSeparators() {
        const container = document.getElementById('view-grid-container');
        if (!container || container.classList.contains('d-none')) return;
        
        const children = Array.from(container.children).filter(el => {
          return !el.classList.contains('separator-break') && !el.classList.contains('d-none');
        });
        
        const colsPerRow = getColsPerRow();
        
        // Ocultar todos los saltos de línea por defecto
        const breaks = container.querySelectorAll('.separator-break');
        breaks.forEach(b => b.classList.add('d-none'));
        
        let currentPosInRow = 0;
        
        children.forEach(el => {
          const isSeparator = el.classList.contains('separator-col');
          
          if (isSeparator) {
            // Si el espacio restante antes del separador (0.5 de ancho) es menor que 1.5 columnas,
            // entonces colocar el separador aquí haría que no quepa ningún show (1.0 de ancho) en la fila.
            // Por lo tanto, el separador quedaría como último elemento de la fila. Forzamos su salto!
            if (colsPerRow - currentPosInRow < 1.5) {
              const letter = el.dataset.letter;
              const breakDiv = container.querySelector(`.separator-break[data-letter="${letter}"]`);
              if (breakDiv) {
                breakDiv.classList.remove('d-none');
              }
              currentPosInRow = 0;
            }
            currentPosInRow += 0.5;
          } else {
            if (currentPosInRow + 1 > colsPerRow) {
              currentPosInRow = 0;
            }
            currentPosInRow += 1.0;
          }
          
          if (currentPosInRow >= colsPerRow) {
            currentPosInRow = 0;
          }
        });
      }

      window.addEventListener('resize', adjustGridSeparators);

      function updateAlphabetNav() {
        const alphabetNav = document.getElementById('alphabet-nav');
        if (!alphabetNav) return;
        
        const selector = currentViewMode === 'list' ? '#view-list-tbody > tr:not(.separator-row)' : '#view-grid-container > .col:not(.separator-col)';
        const elements = document.querySelectorAll(selector);
        
        const activeInitials = new Set();
        elements.forEach(el => {
          if (!el.classList.contains('d-none')) {
            const name = el.dataset.name || '';
            const firstChar = name.charAt(0).toUpperCase();
            let normalizedChar = firstChar;
            if (firstChar !== 'Ñ') {
              normalizedChar = firstChar.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            }
            if (/^[0-9\W]/.test(normalizedChar)) {
              activeInitials.add('#');
            } else {
              activeInitials.add(normalizedChar);
            }
          }
        });
        
        const buttons = alphabetNav.querySelectorAll('.alphabet-link');
        buttons.forEach(btn => {
          const letter = btn.textContent;
          if (activeInitials.has(letter)) {
            btn.classList.remove('disabled');
            btn.classList.add('has-shows');
          } else {
            btn.classList.add('disabled');
            btn.classList.remove('has-shows');
          }
        });
      }

      function initAlphabetNav() {
        const alphabetNav = document.getElementById('alphabet-nav');
        if (!alphabetNav) return;
        
        const letters = ['#','A','B','C','D','E','F','G','H','I','J','K','L','M','N','Ñ','O','P','Q','R','S','T','U','V','W','X','Y','Z'];
        alphabetNav.innerHTML = '';
        
        letters.forEach(letter => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'alphabet-link disabled';
          btn.textContent = letter;
          btn.title = `Ir a la letra ${letter}`;
          
          btn.addEventListener('click', () => {
            const selector = currentViewMode === 'list' ? '.separator-row' : '.separator-col';
            const elements = document.querySelectorAll(selector);
            const target = Array.from(elements).find(el => {
              if (el.classList.contains('d-none')) return false;
              return el.dataset.letter === letter.toLowerCase();
            });
            
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'center' });
              
              // Destello de foco para accesibilidad en el separador
              const innerCard = target.querySelector('.card, td');
              if (innerCard) {
                innerCard.style.transition = 'all 0.3s ease';
                const originalBorder = innerCard.style.borderColor;
                const originalShadow = innerCard.style.boxShadow;
                
                innerCard.style.borderColor = 'var(--bs-purple)';
                innerCard.style.boxShadow = '0 0 15px rgba(111, 66, 193, 0.5)';
                
                setTimeout(() => {
                  innerCard.style.borderColor = originalBorder;
                  innerCard.style.boxShadow = originalShadow;
                }, 1000);
              }
            }
          });
          
          alphabetNav.appendChild(btn);
        });
        
        updateAlphabetNav();
      }

      // Aplicar filtros iniciales
      applyFilters();

      // Inicializar navegación alfabética lateral
      initAlphabetNav();

      toggleBtn.addEventListener('click', () => {
        hideCompleted = !hideCompleted;
        localStorage.setItem('hideCompletedSeries', hideCompleted);
        applyFilters();
      });

      toggleEndedBtn.addEventListener('click', () => {
        hideEnded = !hideEnded;
        localStorage.setItem('hideEndedSeries', hideEnded);
        applyFilters();
      });

      toggleAbandonedBtn.addEventListener('click', () => {
        showOnlyAbandoned = !showOnlyAbandoned;
        localStorage.setItem('showOnlyAbandonedSeries', showOnlyAbandoned);
        applyFilters();
      });

      if (searchInput) {
        searchInput.addEventListener('input', applyFilters);
        searchInput.addEventListener('keyup', (e) => {
          if (e.key === 'Escape') {
            searchInput.value = '';
            applyFilters();
          }
        });
      }
    }
  });
</script>

<%- include('partials/footer') %>
