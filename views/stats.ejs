<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-5">
  <h1 class="fw-black mb-0 text-gradient">📊 Estadísticas y Respaldo</h1>
  
  <!-- Botón Volver -->
  <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
    🏠 Volver al inicio
  </a>
</div>

<!-- Tarjetas de Resumen General de Visualización -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4 mb-5">
  <div class="col">
    <div class="card glass-card p-4 rounded-4 shadow-sm border-0 h-100 text-center">
      <div class="fs-1 mb-2">📺</div>
      <h3 class="fs-6 uppercase fw-semibold mb-1">Series Seguidas</h3>
      <p class="display-6 fw-bold mb-0 text-primary"><%= userStats.totalShows %></p>
    </div>
  </div>

  <div class="col">
    <div class="card glass-card p-4 rounded-4 shadow-sm border-0 h-100 text-center">
      <div class="fs-1 mb-2">🎬</div>
      <h3 class="fs-6 uppercase fw-semibold mb-1">Episodios Vistos</h3>
      <p class="display-6 fw-bold mb-0 text-success">
        <%= userStats.watchedEpisodes %> <span class="fs-6">/ <%= userStats.totalEpisodes %></span>
      </p>
    </div>
  </div>

  <div class="col">
    <div class="card glass-card p-4 rounded-4 shadow-sm border-0 h-100 text-center">
      <div class="fs-1 mb-2">⏱️</div>
      <h3 class="fs-6 uppercase fw-semibold mb-1">Tiempo de Pantalla</h3>
      <p class="display-6 fw-bold mb-0 text-info">
        <%= userStats.totalHoursWatched %> <span class="fs-6">horas</span>
      </p>
    </div>
  </div>

  <div class="col">
    <div class="card glass-card p-4 rounded-4 shadow-sm border-0 h-100 text-center">
      <div class="fs-1 mb-2">🏆</div>
      <h3 class="fs-6 uppercase fw-semibold mb-1">Series Completadas</h3>
      <p class="display-6 fw-bold mb-0 text-warning"><%= userStats.completedShowsCount %></p>
    </div>
  </div>

  <div class="col">
    <div class="card glass-card p-4 rounded-4 shadow-sm border-0 h-100 text-center">
      <div class="fs-1 mb-2">🥀</div>
      <h3 class="fs-6 uppercase fw-semibold mb-1">Series Abandonadas</h3>
      <p class="display-6 fw-bold mb-0 text-danger"><%= userStats.abandonedShowsCount %></p>
    </div>
  </div>
</div>

<div class="row g-4 mb-5">
  <!-- Gráficos de Estadísticas Avanzadas -->
  <div class="col-lg-8">
    <div class="card glass-card p-4 rounded-4 shadow border-0 h-100">
      <h2 class="fs-4 fw-bold mb-4 d-flex align-items-center gap-2">
        <span>📈</span> Análisis de Visualización
      </h2>
      
      <% if (userStats.totalShows === 0) { %>
        <div class="text-center py-5">
          <p class="">Comenzá a seguir algunas series para generar gráficos analíticos.</p>
        </div>
      <% } else { %>
        <div class="row g-4">
          <!-- Gráfico 1: Estado de las series -->
          <div class="col-md-6 text-center">
            <h4 class="fs-6 fw-bold mb-3 ">Estado de las Series</h4>
            <div style="position: relative; height: 200px; width: 100%;">
              <canvas id="statusChart"></canvas>
            </div>
          </div>
          
          <!-- Gráfico 2: Calificaciones de Temporadas -->
          <div class="col-md-6 text-center">
            <h4 class="fs-6 fw-bold mb-3 ">Distribución de Calificaciones</h4>
            <div style="position: relative; height: 200px; width: 100%;">
              <canvas id="ratingsChart"></canvas>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Copias de Seguridad (Backup) -->
  <div class="col-lg-4">
    <div class="card glass-card p-4 rounded-4 shadow border-0 h-100 d-flex flex-column justify-content-between">
      <div>
        <h2 class="fs-4 fw-bold mb-3 d-flex align-items-center gap-2">
          <span>💾</span> Copias de Seguridad
        </h2>
        <p class="small ">Descargá o restaurá tu biblioteca completa. Esto incluye todas tus series seguidas, las calificaciones de las temporadas y el historial de episodios vistos.</p>
        
        <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-warning rounded-3 small p-2 mb-4">
          ⚠️ <strong>Nota:</strong> Al importar una copia de seguridad se combinarán los datos existentes con los del archivo.
        </div>
      </div>

      <div class="d-grid gap-2">
        <!-- Exportar -->
        <a href="/stats/backup/exportar" class="btn btn-primary rounded-pill d-flex align-items-center justify-content-center gap-2 py-2 fw-semibold">
          📥 Exportar Biblioteca (JSON)
        </a>
        
        <!-- Importar -->
        <button id="import-btn" class="btn btn-outline-info rounded-pill d-flex align-items-center justify-content-center gap-2 py-2 fw-semibold">
          📤 Importar Biblioteca
        </button>
        <input type="file" id="backup-file" accept=".json" class="d-none">
      </div>
    </div>
  </div>
</div>

<!-- Consumo de API TheTVDB v4 -->
<div class="row g-4 mb-5">
  <div class="col-lg-8">
    <div class="card glass-card p-4 rounded-4 shadow border-0">
      <h2 class="fs-4 fw-bold mb-4 d-flex align-items-center gap-2">
        <span>🌐</span> Consumo de API TheTVDB v4
      </h2>
      
      <!-- Progreso Anual contra el Límite -->
      <div class="mb-4">
        <div class="d-flex justify-content-between mb-2 small fw-semibold">
          <span class="">Uso del Límite Anual (50.000 consultas)</span>
          <span class="text-info"><%= apiStats.year %> / <%= apiStats.limit %> (<%= apiStats.percentageUsed %>%)</span>
        </div>
        <div class="progress rounded-pill" style="height: 14px;">
          <% 
            let progressBarColor = 'bg-info';
            if (apiStats.percentageUsed > 75) progressBarColor = 'bg-warning';
            if (apiStats.percentageUsed > 90) progressBarColor = 'bg-danger';
          %>
          <div class="progress-bar progress-bar-striped <%= progressBarColor %> rounded-pill" role="progressbar" style="width: <%= Math.min(apiStats.percentageUsed, 100) %>%" aria-valuenow="<%= apiStats.year %>" aria-valuemin="0" aria-valuemax="<%= apiStats.limit %>"></div>
        </div>
      </div>

      <div class="row g-3 text-center">
        <div class="col-6 col-md-4">
          <div class="bg-dark bg-opacity-25 rounded-3 p-3 border border-secondary border-opacity-10">
            <span class="small d-block ">Consultas Hoy</span>
            <strong class="fs-4"><%= apiStats.today %></strong>
          </div>
        </div>
        <div class="col-6 col-md-4">
          <div class="bg-dark bg-opacity-25 rounded-3 p-3 border border-secondary border-opacity-10">
            <span class="small d-block ">Consultas este Mes</span>
            <strong class="fs-4"><%= apiStats.month %></strong>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="bg-dark bg-opacity-25 rounded-3 p-3 border border-secondary border-opacity-10">
            <span class="small d-block ">Consultas este Año</span>
            <strong class="fs-4"><%= apiStats.year %></strong>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Explicación de la cuota -->
  <div class="col-lg-4">
    <div class="card glass-card p-4 rounded-4 shadow border-0 h-100">
      <h3 class="fs-5 fw-bold mb-3 text-warning">⚠️ Acerca del Límite</h3>
      <p class="small ">Tu clave de API de TheTVDB v4 cuenta con un límite estricto de **50.000 solicitudes al año**.</p>
      <p class="small ">Para optimizar tu consumo y evitar cargos, ShowTracker aplica las siguientes técnicas:</p>
      <ul class="small ps-3 ">
        <li>Guarda localmente la metadata de las series y episodios una vez consultados.</li>
        <li>Descarga las imágenes a la carpeta local para no hacer peticiones repetidas.</li>
        <li>Actualiza la información solo cuando lo decidas de forma manual.</li>
      </ul>
    </div>
  </div>
</div>

<!-- Tabla de Registros Recientes -->
<h2 class="fs-4 fw-bold mb-4 d-flex align-items-center gap-2">
  <span>📜</span> Historial Reciente de Consultas
</h2>

<div class="card glass-card rounded-4 border-0 overflow-hidden shadow mb-5">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle" style="color: inherit;">
      <thead>
        <tr class="table-black " style="font-size: 0.85rem;">
          <th scope="col" class="ps-4">Fecha</th>
          <th scope="col">Endpoint / Acción</th>
          <th scope="col" class="text-end pe-4">Cantidad de Llamadas</th>
        </tr>
      </thead>
      <tbody class="">
        <% if (apiLogs.length === 0) { %>
          <tr>
            <td colspan="3" class="text-center py-4">Aún no se registraron llamadas a la API.</td>
          </tr>
        <% } else { %>
          <% apiLogs.forEach(log => { %>
            <tr>
              <td class="ps-4"><%= log.date %></td>
              <td><code><%= log.type %></code></td>
              <td class="text-end pe-4 fw-bold text-info"><%= log.calls %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Cargar Chart.js desde CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ----------------------------------------------------
    // Lógica de Gráficos (Chart.js)
    // ----------------------------------------------------
    <% if (userStats.totalShows > 0) { %>
      // Datos pasados desde el backend
      const statusData = {
        continuing: <%= advancedStats.status.continuing || 0 %>,
        ended: <%= advancedStats.status.ended || 0 %>,
        other: <%= advancedStats.status.other || 0 %>
      };
      
      const ratingsData = <%= JSON.stringify(advancedStats.ratingsDistribution) %>;

      let statusChartInstance;
      let ratingsChartInstance;

      function initCharts() {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const textColor = isDark ? '#fff' : '#334155';
        const gridColor = isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
        const chartBorderColor = isDark ? '#212529' : '#ffffff';

        // 1. Gráfico de Estados de Series (Dona)
        const ctxStatus = document.getElementById('statusChart').getContext('2d');
        statusChartInstance = new Chart(ctxStatus, {
          type: 'doughnut',
          data: {
            labels: ['En emisión', 'Terminadas', 'Otros'],
            datasets: [{
              data: [statusData.continuing, statusData.ended, statusData.other],
              backgroundColor: ['#198754', '#dc3545', '#6c757d'],
              borderColor: chartBorderColor,
              borderWidth: 1
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  color: textColor,
                  font: { size: 10 }
                }
              }
            }
          }
        });

        // 2. Gráfico de Calificaciones (Barras)
        const ctxRatings = document.getElementById('ratingsChart').getContext('2d');
        ratingsChartInstance = new Chart(ctxRatings, {
          type: 'bar',
          data: {
            labels: ['1★', '2★', '3★', '4★', '5★'],
            datasets: [{
              label: 'Temporadas',
              data: ratingsData,
              backgroundColor: '#6f42c1',
              borderColor: '#8f62d1',
              borderWidth: 1,
              borderRadius: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false }
            },
            scales: {
              x: {
                grid: { display: false },
                ticks: { color: textColor, font: { size: 10 } }
              },
              y: {
                grid: { color: gridColor },
                ticks: { 
                  color: textColor,
                  font: { size: 10 },
                  stepSize: 1
                }
              }
            }
          }
        });
      }

      function updateChartThemes() {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const textColor = isDark ? '#fff' : '#334155';
        const gridColor = isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
        const chartBorderColor = isDark ? '#212529' : '#ffffff';

        if (statusChartInstance) {
          statusChartInstance.options.plugins.legend.labels.color = textColor;
          statusChartInstance.data.datasets[0].borderColor = chartBorderColor;
          statusChartInstance.update();
        }

        if (ratingsChartInstance) {
          ratingsChartInstance.options.scales.x.ticks.color = textColor;
          ratingsChartInstance.options.scales.y.ticks.color = textColor;
          ratingsChartInstance.options.scales.y.grid.color = gridColor;
          ratingsChartInstance.update();
        }
      }

      // Inicializar gráficos
      initCharts();

      // Observador de cambios del tema
      const observer = new MutationObserver(() => {
        updateChartThemes();
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
    <% } %>

    // ----------------------------------------------------
    // Lógica de Backup (Importar)
    // ----------------------------------------------------
    const importBtn = document.getElementById('import-btn');
    const backupFile = document.getElementById('backup-file');

    if (importBtn && backupFile) {
      importBtn.addEventListener('click', () => {
        backupFile.click();
      });

      backupFile.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const confirmImport = confirm('¿Seguro querés importar este respaldo? Esto fusionará tus datos actuales con los del archivo JSON seleccionado.');
        if (!confirmImport) {
          backupFile.value = ''; // Limpiar
          return;
        }

        const reader = new FileReader();
        reader.onload = async (event) => {
          try {
            const backupData = JSON.parse(event.target.result);
            
            // Validación básica
            if (!backupData.series || !backupData.ratings || !backupData.episodes) {
              alert('Error: El archivo de copia de seguridad no tiene el formato correcto de ShowTracker.');
              backupFile.value = '';
              return;
            }

            importBtn.disabled = true;
            importBtn.innerText = '⏳ Importando...';

            const response = await fetch('/stats/backup/importar', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(backupData)
            });

            const result = await response.json();
            if (result.success) {
              alert('✅ Copia de seguridad importada con éxito.');
              window.location.reload();
            } else {
              alert(`❌ Error al importar: ${result.error}`);
            }
          } catch (err) {
            console.error(err);
            alert('❌ Ocurrió un error al procesar el archivo. Asegurate de que sea un JSON válido.');
          } finally {
            importBtn.disabled = false;
            importBtn.innerText = '📤 Importar Biblioteca';
            backupFile.value = ''; // Limpiar
          }
        };

        reader.readAsText(file);
      });
    }
  });
</script>

<%- include('partials/footer') %>
