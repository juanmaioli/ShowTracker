<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ShowTracker</title>
  <!-- Evitar destellos cargando la preferencia inmediatamente -->
  <script>
    const savedTheme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-bs-theme', savedTheme);
  </script>
  <!-- Bootstrap 5.3 CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <!-- Extensión de Colores Local -->
  <link rel="stylesheet" href="/css/bootstrap-color-extension.css">
  <!-- Favicon Emoji -->
  <link class="favicon" rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📺</text></svg>">
  <style>
    /* Hero Section */
    .hero-section {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      padding: 30px 0;
      border-bottom: 1px solid #34495e;
    }

    /* Variables dinámicas para el tema */
    [data-bs-theme="dark"] {
      --bg-gradient: linear-gradient(135deg, #0f1015 0%, #151821 100%);
      --border-color: rgba(255, 255, 255, 0.08);
      --card-bg: rgba(26, 29, 41, 0.65);
      --text-color: #cbd5e1;
      --shadow-intensity: rgba(0, 0, 0, 0.35);
      --shadow-hover-intensity: rgba(0, 0, 0, 0.45);
    }

    [data-bs-theme="light"] {
      --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
      --border-color: rgba(0, 0, 0, 0.08);
      --card-bg: rgba(255, 255, 255, 0.75);
      --text-color: #334155;
      --shadow-intensity: rgba(15, 23, 42, 0.06);
      --shadow-hover-intensity: rgba(15, 23, 42, 0.1);
    }

    body {
      background: var(--bg-gradient) !important;
      background-attachment: fixed !important;
      color: var(--text-color) !important;
      transition: background 0.3s ease, color 0.3s ease;
    }

    /* Tarjetas glassmorphism premium */
    .glass-card {
      background: var(--card-bg) !important;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-color) !important;
      box-shadow: 0 10px 30px var(--shadow-intensity);
      transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    }

    .glass-card:hover {
      box-shadow: 0 15px 40px var(--shadow-hover-intensity);
    }

    .poster-container {
      position: relative;
      overflow: hidden;
      border-radius: 8px;
    }
    .poster-image {
      transition: transform 0.3s ease;
    }
    .poster-container:hover .poster-image {
      transform: scale(1.05);
    }
    .cursor-pointer {
      cursor: pointer;
    }
    .nav-link{
      color: #fff;
    }
  </style>
  <!-- Lógica Cliente de Tema -->
  <script src="/js/theme.js" defer></script>
</head>
<body class="min-vh-100 d-flex flex-column">
 <!-- Header Hero -->
  <div class="hero-section text-center text-white shadow">
    <div class="container position-relative">
      <h1 class="display-3 fw-bold mb-1">
        📺 ShowTracker
      </h1>

      <nav class="navbar navbar-expand-lg">
        <div class="container">
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto gap-2 align-items-center mb-3 mb-lg-0">
              <li class="nav-item">
                <a class="nav-link <%= activePage === 'home' ? 'active text-primary fw-semibold' : '' %>" href="/">Inicio</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= activePage === 'search' ? 'active text-primary fw-semibold' : '' %>" href="/series/buscar">Buscar</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= activePage === 'stats' ? 'active text-primary fw-semibold' : '' %>" href="/stats">Estadísticas</a>
              </li>
            </ul>
            <div class="ms-lg-3 d-flex justify-content-center">
              <!-- Selector de Tema con Emojis -->
              <div class="form-check form-switch d-flex align-items-center gap-2 border border-secondary-subtle rounded-pill shadow-sm m-0 cursor-pointer" title="Cambiar tema claro/oscuro" style="cursor: pointer;">
                <span class="fs-7 select-none" aria-hidden="true" style="user-select: none;">☀️</span>
                <input class="form-check-input ms-0 me-0" type="checkbox" id="theme-switch" role="switch" aria-label="Cambiar tema de la aplicación (claro u oscuro)" checked style="cursor: pointer;">
                <span class="fs-7 select-none" aria-hidden="true" style="user-select: none;">🌙</span>
              </div>
            </div>
          </div>
        </div>
      </nav>     

    </div>
  </div>  
  <main class="container flex-grow-1 pb-5 mt-3">
